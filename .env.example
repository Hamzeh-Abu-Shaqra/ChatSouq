# --- Database ---
# Local dev (Homebrew postgresql@17). Swap to Neon/Supabase by changing this URL only.
DATABASE_URL="postgresql://Hamzeh23@localhost:5432/chatsouq"

# --- AI provider (abstraction layer; Claude is primary) ---
# AI_PROVIDER: "claude" | "openai" | "mock"
# "mock" runs the full app with NO API key (deterministic local reasoning).
AI_PROVIDER="mock"
ANTHROPIC_API_KEY=""
ANTHROPIC_MODEL="claude-opus-4-8"
OPENAI_API_KEY=""

# --- Embeddings ---
# EMBEDDING_PROVIDER: "local" (no key, 256-dim hashed) | "openai" | "voyage"
EMBEDDING_PROVIDER="local"

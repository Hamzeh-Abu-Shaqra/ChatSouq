{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "framework": "nextjs",
  "buildCommand": "cd ../.. && pnpm turbo build --filter=@chatsouq/web",
  "outputDirectory": ".next",
  "installCommand": "npm install -g pnpm@11.5.2 && cd ../.. && pnpm install --frozen-lockfile",
  "env": {
    "CHATSOUQ_MODELS_DIR": "/tmp/.chatsouq-models"
  }
}
